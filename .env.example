# Upstash Redis (required for distributed rate limiting)
# Get your REST URL and token from https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# VAPI Voice AI (Track B -- AI voice agent)
# Get your public key from https://dashboard.vapi.ai
# This is a PUBLIC key -- safe to expose to the browser.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here
